<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_app_gradient">

    <LinearLayout
        android:id="@+id/chatHeaderContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:orientation="vertical"
        android:padding="14dp"
        android:background="@drawable/header_hero_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackMain"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/onPrimary"
                android:text="@string/btn_back_dashboard"
                app:icon="@android:drawable/ic_media_previous"
                app:iconTint="@color/onPrimary"
                app:iconGravity="textStart" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/chat_title"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="@color/onPrimary" />

        <TextView
            android:id="@+id/txtChatState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/chat_subtitle"
            android:textSize="12sp"
            android:textColor="#E7F0FF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenAnefFromChat"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/onPrimary"
            android:text="@string/btn_access_anef_site"
            android:maxLines="1"
            android:ellipsize="end"
            app:icon="@android:drawable/ic_menu_view"
            app:iconTint="@color/onPrimary"
            app:strokeColor="@color/onPrimary"
            app:iconGravity="textStart" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/chatGuidesContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@drawable/panel_bg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/quick_guides_title"
            android:textStyle="bold"
            android:textColor="@color/onSurface" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuickDocuments"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/quick_documents" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuickDelais"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/quick_delais" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuickEntretien"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/quick_entretien" />

                <Space
                    android:layout_width="8dp"
                    android:layout_height="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnQuickRecours"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/quick_recours" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_margin="12dp"
        android:orientation="vertical"
        android:padding="10dp"
        android:background="@drawable/panel_bg">

        <ScrollView
            android:id="@+id/chatScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:background="#F8FAFC">

            <LinearLayout
                android:id="@+id/chatContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp" />
        </ScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/edtChatInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/chat_hint"
                android:inputType="textCapSentences|textMultiLine"
                android:imeOptions="actionSend"
                android:maxLines="3"
                android:minLines="1"
                android:minHeight="52dp"
                android:gravity="top|start"
                android:background="@drawable/panel_soft"
                android:textColor="@color/onSurface"
                android:textColorHint="@color/onSurfaceMuted"
                android:textSize="16sp"
                android:padding="12dp" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVoiceInput"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:contentDescription="@string/chat_voice_input_desc"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="52dp"
                android:minHeight="52dp"
                app:icon="@android:drawable/ic_btn_speak_now"
                app:iconGravity="textStart"
                app:iconTint="@color/primary"
                app:strokeColor="@color/primary" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendChat"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:contentDescription="@string/chat_send_desc"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="52dp"
                android:minHeight="52dp"
                app:icon="@android:drawable/ic_menu_send"
                app:iconTint="@color/onPrimary"
                app:backgroundTint="@color/primary" />
        </LinearLayout>
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bottom_nav_bg"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:itemIconTint="@color/bottom_nav_item_color"
        app:itemTextColor="@color/bottom_nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>
