{
  "manifest_version": 3,
  "name": "Statut API du Dossier Naturalisation",
  "version": "2.9.24",
  "description": "Statut API du Dossier Naturalisation",
  "permissions": [
    "scripting",
    "activeTab",
    "alarms",
    "notifications",
    "storage"
  ],
  "host_permissions": [
    "https://administration-etrangers-en-france.interieur.gouv.fr/*",
    "https://sso.anef.dgef.interieur.gouv.fr/*",
    "https://franceconnect.gouv.fr/*",
    "https://*.franceconnect.gouv.fr/*",
    "https://*.impots.gouv.fr/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Suivi Naturalisation (sync + notifications)",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://administration-etrangers-en-france.interieur.gouv.fr/*"
      ],
      "js": [
        "inject.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://administration-etrangers-en-france.interieur.gouv.fr/*",
        "https://sso.anef.dgef.interieur.gouv.fr/*",
        "https://franceconnect.gouv.fr/*",
        "https://*.franceconnect.gouv.fr/*",
        "https://*.impots.gouv.fr/*"
      ],
      "js": [
        "auth-automation.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content.js",
        "crypto-js.min.js",
        "forge.min.js"
      ],
      "matches": [
        "https://administration-etrangers-en-france.interieur.gouv.fr/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
